{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["../../src/*"],
      "@shared": ["../../shared/index.ts"],
      "@shared/*": ["../../shared/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src", "App.tsx", "../../shared"]
}
