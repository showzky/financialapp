{
  "expo": {
    "name": "OrionLedger",
    "slug": "orion-ledger",
    "version": "1.0.3",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0e",
    "icon": "./src/assets/AppIconV1.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.financialapp"
    },
    "android": {
      "package": "com.yourcompany.financialapp",
      "backgroundColor": "#0a0a0e",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/AppIconV1.png",
        "backgroundColor": "#0a0a0e"
      }
    },
    "splash": {
      "backgroundColor": "#0a0a0e"
    },
    "plugins": [
      "expo-notifications",
      "expo-font",
      "expo-asset",
      "@react-native-community/datetimepicker"
    ]
  }
}
