{
  "expo": {
    "name": "Financial App",
    "slug": "financial-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0e",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.financialapp"
    },
    "android": {
      "package": "com.yourcompany.financialapp",
      "backgroundColor": "#0a0a0e"
    },
    "splash": {
      "backgroundColor": "#0a0a0e"
    },
    "plugins": [
      "expo-notifications",
      "expo-font",
      "expo-asset",
      "@react-native-community/datetimepicker"
    ]
  }
}
